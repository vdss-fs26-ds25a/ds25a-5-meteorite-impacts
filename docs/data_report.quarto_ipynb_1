        "mass = eda_df[\"mass_g\"].clip(lower=0.01)\n",
        "ax.hist(np.log10(mass), bins=150, color=\"steelblue\", edgecolor=\"none\")\n",
        "\n",
        "ax.set_title(\"Mass Distribution of Meteorites (log scale)\", fontsize=15, weight=\"bold\")\n",
        "ax.set_xlabel(\"log10(Mass in g)\")\n",
        "ax.set_ylabel(\"Count\")\n",
        "\n",
        "plt.tight_layout()\n",
