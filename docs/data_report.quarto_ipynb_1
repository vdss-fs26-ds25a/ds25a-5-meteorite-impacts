      "source": [
        "#| label: fig-demo2\n",
        "#| fig-cap: Meteorites over the world\n",
        "#| echo: false\n",
        "#| code-fold: true\n",
        "\n",
        "import cartopy.crs as ccrs\n",
        "import cartopy.feature as cfeature\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import pandas as pd\n",
        "from pathlib import Path\n",
        "\n",
        "data_path = Path(\"../data/processed/Meteorite_Landings_cleaned.csv\")\n",
        "df = pd.read_csv(data_path)\n",
        "\n",
        "df[\"year\"] = pd.to_numeric(df[\"year\"], errors=\"coerce\")\n",
        "df[\"mass_g\"] = pd.to_numeric(df[\"mass_g\"], errors=\"coerce\")\n",
        "df[\"reclat\"] = pd.to_numeric(df[\"reclat\"], errors=\"coerce\")\n",
        "df[\"reclong\"] = pd.to_numeric(df[\"reclong\"], errors=\"coerce\")\n",
        "\n",
        "eda_df = df\n",
        "top_classes = eda_df[\"recclass\"].value_counts().head(15).sort_values()\n",
        "\n",
        "fig = plt.figure(figsize=(10, 5))\n",
        "ax = plt.axes(projection=ccrs.PlateCarree())\n",
        "\n",
        "# Weltkarte\n",
        "ax.add_feature(cfeature.LAND, facecolor=\"#f2f2f2\")\n",
        "ax.add_feature(cfeature.OCEAN, facecolor=\"#d9ecff\")\n",
        "ax.add_feature(cfeature.COASTLINE, linewidth=0.5)\n",
        "ax.add_feature(cfeature.BORDERS, linewidth=0.3)\n",
        "\n",
        "# Daten trennen\n",
        "found = eda_df[eda_df[\"fall\"] != \"Fell\"]\n",
        "fell = eda_df[eda_df[\"fall\"] == \"Fell\"]\n",
        "\n",
        "# Found (blau)\n",
        "ax.scatter(\n",
        "    found[\"reclong\"],\n",
        "    found[\"reclat\"],\n",
        "    color=\"blue\",\n",
        "    s=10,\n",
        "    alpha=0.4,\n",
        "    transform=ccrs.PlateCarree(),\n",
        "    label=\"Found\"\n",
        ")\n",
        "\n",
        "# Fell (rot)\n",
        "ax.scatter(\n",
        "    fell[\"reclong\"],\n",
        "    fell[\"reclat\"],\n",
        "    color=\"red\",\n",
        "    s=10,\n",
        "    alpha=0.4,\n",
        "    transform=ccrs.PlateCarree(),\n",
        "    label=\"Fell\"\n",
        ")\n",
        "\n",
        "# Titel\n",
        "ax.set_title(\"Meteorite Landing and Recovery Locations\", fontsize=15, weight=\"bold\")\n",
        "ax.set_global()\n",
        "\n",
        "# Grid\n",
        "gl = ax.gridlines(draw_labels=True, linestyle=\"--\", alpha=0.25)\n",
        "gl.top_labels = False\n",
        "gl.right_labels = False\n",
        "\n",
        "# Legende\n",
        "ax.legend(loc=\"lower left\")\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
      "id": "fig-demo2",
      "execution_count": null,
      "outputs": []
